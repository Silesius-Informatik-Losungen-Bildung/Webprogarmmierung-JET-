@model List<Ap12Web.Models.Produkt>

<!DOCTYPE html>
<html>
<head>
    <title>Produktübersicht</title>
</head>
<body>

    <table border="1" cellpadding="5" cellspacing="0">
        <tr>
            <th>Bezeichnung</th>
            <th>Preis</th>
            <th>Hersteller</th>
            <th>Details</th>
        </tr>
        @foreach(var produkt in Model)
        {
            <tr>
                <td>@produkt.Bezeichnung</td>
                <td>@produkt.Preis.ToString("0.00")</td>
                <td>@produkt.Hersteller</td>
                <td><a href="/Produkt/Details?id=@produkt.ProduktId">Details</a></td>
            </tr>
        }
    </table>

    <br />

    <a href="/Produkt/Erfassen">Noch ein Produkt erfassen</a>


</body>
</html>